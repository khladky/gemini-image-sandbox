{
  "manifest_version": 3,
  "name": "Gemini Image Sandbox",
  "version": "1.0.0",
  "description": "Experiment with Gemini AI queries against any image",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://www.flickr.com/*",
    "https://live.staticflickr.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.flickr.com/photos/*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}